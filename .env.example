# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Web API (Phase 6d~) ---
# pydantic-settings가 JSON 배열로 파싱. 쉼표 구분 문자열 아님 주의.
CORS_ORIGINS=["http://localhost:3000"]
API_CONCURRENCY_LIMIT=5

# Naver crawling (optional overrides)
# NAVER_CONCURRENT_REQUESTS=5
# NAVER_REQUEST_DELAY_MS=300
# NAVER_MAX_RETRIES=3

# Cache TTL in seconds (optional overrides)
# CACHE_PRICE_INTRADAY_TTL_SEC=300
# CACHE_PRICE_EOD_TTL_SEC=43200
# CACHE_FUNDAMENTAL_TTL_SEC=86400
# CACHE_LLM_TTL_SEC=86400
# CACHE_TICKER_MASTER_TTL_SEC=604800

# --- Frontend ---
# 브라우저가 읽는 값이므로 호스트 관점 URL 사용 (docker-compose에서도 동일).
NEXT_PUBLIC_API_URL=http://localhost:8000
